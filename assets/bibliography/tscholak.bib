@misc{scholak2010entanglementriezlern,
	Abstract = {In many areas of physics we witness dramatic differences between classical and quantum transport. In general, we expect quantum features to fade away on large scales, due to the ever more unavoidable -- and detrimental -- influence of the environment which scrambles relative phases and damps quantum amplitudes. Recent experimental evidence suggests, however, that the functional efficiency of large biomolecular units may stem from quantum coherence phenomena, despite strong environment coupling. We explain such efficiency, under the assumption that evolution is able to steer finite size three dimensional systems into molecular conformations with optimal coherent transport properties. It turns out that such optimal conformations are characterized by specific, optimal entanglement properties between different sites of the molecular complex.},
	Author = {Scholak, Torsten},
	Date-Added = {2015-03-02 16:59:23 +0000},
	Date-Modified = {2015-03-02 17:09:29 +0000},
	Howpublished = {talk given at the 31th EAS (Energiereiche Atomare Stöße) meeting in Riezlern, Austria},
	Month = {February},
	Status = {talk},
	Title = {Entanglement-enhanced efficient energy transport},
	Year = {2010}}

